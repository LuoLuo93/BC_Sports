<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bcsport.admin.ihrmapper.IhrAccessTokenMapper">
    <delete id="deleteAll">TRUNCATE TABLE access_token</delete>
    <insert id="insertBatch">
        INSERT INTO access_token(id, access_token, expires_in, create_time, update_time)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.id}, #{item.accessToken}, #{item.expiresIn}, GETDATE(), GETDATE())
        </foreach>
    </insert>
</mapper>
