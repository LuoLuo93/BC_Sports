<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bcsport.admin.ihrmapper.IhrEmployeesAuxiliaryMapper">
    <delete id="deleteAll">DELETE FROM employees_auxiliary</delete>
    <insert id="insertBatch">
        INSERT INTO employees_auxiliary(employees_id, create_time)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.employeesId}, GETDATE())
        </foreach>
    </insert>
</mapper>
