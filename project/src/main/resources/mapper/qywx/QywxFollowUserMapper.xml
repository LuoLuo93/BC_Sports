<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bcsport.admin.qywxmapper.QywxFollowUserMapper">
    <select id="selectAllUserIds" resultType="java.lang.String">
        SELECT follow_user FROM VX_FollowUserList
    </select>
    <delete id="deleteAll">DELETE FROM VX_FollowUserList</delete>
    <insert id="insertBatch">
        INSERT INTO VX_FollowUserList(id, follow_user, createTime)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.id}, #{item.followUser}, GETDATE())
        </foreach>
    </insert>
</mapper>
